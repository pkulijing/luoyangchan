# ============================================
# 前端部署必需（Vercel Environment Variables）
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 天地图（前端底图瓦片服务）
NEXT_PUBLIC_TIANDITU_TK=your_tianditu_tk

# 地图提供者切换 amap/tianditu
NEXT_PUBLIC_MAP_PROVIDER=amap

# 高德地图 JS API
NEXT_PUBLIC_AMAP_KEY=your_amap_js_api_key
NEXT_PUBLIC_AMAP_SECRET=your_amap_security_code


# 百度百科图片开关（默认 true，设为 false 可禁用百度 CDN 图片）
NEXT_PUBLIC_USE_BAIKE_IMAGES=true

# ============================================
# 仅本地脚本使用（无需配置到 Vercel）
# ============================================

# 高德地图 Web 服务（地理编码 Python 脚本）
AMAP_GEOCODING_KEY=your_amap_web_service_key

# DeepSeek API（数据富化脚本，描述/标签生成）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASEURL=https://api.deepseek.com

# 腾讯地图 Web 服务（地理编码 Python 脚本）
TENCENT_MAP_KEY=your_tencent_map_key
TENCENT_MAP_SIGN_SECRET_KEY=your_tencent_sign_secret

# Google OAuth（可选，在 Supabase Dashboard 配置，不走 Vercel）
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
